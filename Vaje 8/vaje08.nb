    RowBox[{"50", ",", "60", ",", "70", ",", "80", ",", "90"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  StyleBox["ocene",
   FontWeight->"Bold"], 
  StyleBox[" ",
