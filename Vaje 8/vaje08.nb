Cell[TextData[{
 StyleBox["1. a)",
  FontWeight->"Bold"],
 " Z ukazom \[OpenCurlyQuote]Directory\[CloseCurlyQuote] preveri delovno \
podro\[CHacek]je. Nato z uporabo \[OpenCurlyQuote]SetDirectory\
\[CloseCurlyQuote] in \[OpenCurlyQuote]NotebookDirectory\[CloseCurlyQuote] \
nastavi delovno podro\[CHacek]je na ustrezno mapo. "
}], "Text",
