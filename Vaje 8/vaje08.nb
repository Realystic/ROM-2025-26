Cell[TextData[{
 StyleBox["4.",
  FontWeight->"Bold"],
 " Sestavi funkcijo ",
 StyleBox["DodajStolpec[podatki_]",
  FontWeight->"Bold"],
 ", ki obstoje\[CHacek]i tabeli doda \[SHacek]e en stolpec (oz . vrne novo \
tabelo z dodanim stolpcem) . Premisli, kako s pomo\[CHacek]jo \
\[OpenCurlyQuote]Query\[CloseCurlyQuote] doda\[SHacek] stolpec tabeli.  \
Podatkom dodaj stolpec \"Ocena\" z ocenami in vse skupaj shrani v \
spremenljivko ",
 StyleBox["podatkiOcene",
  FontSlant->"Italic"],
 ". Novo tabelo shrani v Excelov zvezek \[OpenCurlyQuote]ocene.xlsx\
\[CloseCurlyQuote] s pomo\[CHacek]jo ukaza \[OpenCurlyQuote]Export\
\[CloseCurlyQuote] ."
}], "Text",
 CellChangeTimes->{{3.9852397776051655`*^9, 3.9852397800421305`*^9}, {
  3.9852398126988883`*^9, 3.9852399085416565`*^9}, {3.985274011227133*^9, 
  3.985274014265061*^9}, {3.9852745439486957`*^9, 
  3.9852745447927713`*^9}},ExpressionUUID->"ddafbd4d-e66d-4101-964e-\
c054ea633987"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DodajStolpec", "[", "podatki_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Query", "[", 
    RowBox[{"All", ",", 
     RowBox[{
      RowBox[{"<|", 
       RowBox[{"#", ",", 
        RowBox[{"\"\<Ocena\>\"", "->", 
         RowBox[{"OcenaZaMeje", "[", 
          RowBox[{"meje", ",", 
           RowBox[{"#", "[", "\"\<To\[CHacek]ke\>\"", "]"}]}], "]"}]}]}], 
       "|>"}], "&"}]}], "]"}], "@", "podatki"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"podatkiOcene", " ", "=", " ", 
   RowBox[{"DodajStolpec", "[", "podatki", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Export", "[", 
   RowBox[{"\"\<ocene.xlsx\>\"", ",", "podatkiOcene"}], "]"}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.985327187537014*^9, 3.985327199254759*^9}, {
   3.9853272296118965`*^9, 3.9853272352039623`*^9}, 3.985327310480528*^9, {
   3.985328034071169*^9, 3.9853281049289303`*^9}, {3.985328136124857*^9, 
   3.985328190569319*^9}, {3.9853282329057617`*^9, 3.9853283129135094`*^9}, {
   3.9853283439774876`*^9, 3.985328350374262*^9}, {3.9853284039260063`*^9, 
   3.985328463844183*^9}, {3.98593356960812*^9, 3.985933573111887*^9}},
 CellLabel->
  "In[128]:=",ExpressionUUID->"8cbac7b1-d42c-094c-a33e-9ef33adb42b5"],

Cell[TextData[{
 StyleBox["5.",
  FontWeight->"Bold"],
 " Preveri, kaj naredi funkcija \[OpenCurlyQuote]BinCount\[CloseCurlyQuote] \
na seznamu ocen. Ali bi se dele rezultata te funkcije dalo uporabiti, da bi \
pre\[SHacek]teli, koliko \[SHacek]tudentov je dobilo kak\[SHacek]no \
oceno(Da)? Namig : uporabi\[SHacek] lahko funkcije za delo s seznami kot so \
Rest, Drop, Take, ... Izra\[CHacek]unaj porazdelitev ocen in jo shrani v \
spremenljivko \[OpenCurlyQuote]porazdelitevOcen\[CloseCurlyQuote]. To je \
seznam \[SHacek]estih vrednosti, pri \[CHacek]emer prva predstavlja \
\[SHacek]tevilo \[SHacek]tudentov z negativno oceno, druga \[SHacek]tevilo \
\[SHacek]tudentov z oceno 6, . . ."
}], "Text",
 CellChangeTimes->{{3.9852399435235586`*^9, 3.9852399714010763`*^9}, {
  3.9852405189352884`*^9, 3.985240584166198*^9}, {3.985329512740549*^9, 
  3.985329514102186*^9}},ExpressionUUID->"22b9d7e8-af8a-47ef-94ba-\
cc72a7f9157a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"porazdelitevOcen", " ", "=", " ", 
  RowBox[{"Drop", "[", 
   RowBox[{
    RowBox[{"BinCounts", "[", 
     RowBox[{"ocene", ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "11", ",", "1"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"2", ",", "6"}], "}"}]}], "]"}], "  ", 
  RowBox[{"(*", 
   RowBox[{
   "dobi", " ", "seznam", " ", "\"\<ocene\>\"", " ", "in", " ", "ga", " ", 
    "spremeni", " ", "v", " ", "sseznam", " ", "kjer", " ", "je", " ", "vsak",
     " ", "element", " ", "\[SHacek]tevilo", " ", "pojavitev", " ", 
    "dolo\[CHacek]enega", " ", "\[SHacek]tevila", "  ", 
    RowBox[{"(", 
     RowBox[{
     "to", " ", "od", " ", "0", " ", "do", " ", "vklju\[CHacek]no", " ", "10",
       " ", "pro", " ", "inkrementu", " ", "1"}], ")"}], " ", "in", " ", 
    "odstranimo", " ", "vse", "\[IndentingNewLine]", 
    "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t", "prazne", " ", "elemente", " ", 
    RowBox[{"(", "ni\[CHacek]le", ")"}]}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.9853285425560493`*^9, 3.9853285507932434`*^9}, {
   3.985328583707609*^9, 3.9853285997880917`*^9}, {3.9853294234448776`*^9, 
