Cell[TextData[{
 StyleBox["3.",
  FontWeight->"Bold"],
 " Sestavi funkcijo ",
 StyleBox["OcenaZaMeje[{za6_, za7_, za8_, za9_, za10_}, tocke_]",
  FontWeight->"Bold"],
 ", pri kateri so v prvem argumentu meje za ocene v \[SHacek]tevilu to\
\[CHacek]k, v drugem argumentu pa \[SHacek]tevilo to\[CHacek]k, za katere\n\
\[ZHacek]elimo izra\[CHacek]unati oceno. Funkcijo napi\[SHacek]i s pomo\
\[CHacek]jo ustreznih stavkov \[OpenCurlyQuote]If\[CloseCurlyQuote]. Nato \
siesta funkcijo ",
 StyleBox["Ocene[podatki_, meje_]",
  FontWeight->"Bold"],
 ", ki izra\[CHacek]una stolpec ocen za dane podatke in meje."
}], "Text",
 CellChangeTimes->{{3.985239644692469*^9, 3.985239784122751*^9}, 
   3.985324965977642*^9},ExpressionUUID->"fa46e67f-a2c0-400c-9e56-\
76011006aee7"],

Cell[CellGroupData[{

Cell[BoxData[{
 StyleBox[
  RowBox[{
   RowBox[{"OcenaZaMeje", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "za6_", ",", " ", "za7_", ",", " ", "za8_", ",", " ", "za9_", ",", " ", 
       "za10_"}], "}"}], ",", " ", "tocke_"}], "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"tocke", ">=", "za10"}], ",", "10", ",", "\[IndentingNewLine]", 
     "\t\t", "\t\t", "\t\t", "\t\t", "\t\t", "\t\t", "\t\t", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"tocke", ">=", "za9"}], ",", "9", ",", "\[IndentingNewLine]", 
       "\t\t", "\t\t", "\t\t", "\t\t", "\t\t", "\t\t", "\t\t", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"tocke", ">=", "za8"}], ",", "8", ",", "\[IndentingNewLine]",
          "\t\t", "\t\t", "\t\t", "\t\t", "\t\t", "\t\t", "\t\t", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"tocke", ">=", "za7"}], ",", "7", ",", 
           "\[IndentingNewLine]", "\t\t", "\t\t", "\t\t", "\t\t", "\t\t", 
           "\t\t", "\t\t", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"tocke", ">=", "za6"}], ",", "6", ",", "0"}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}]}], "]"}]}],
  FontWeight->"Bold"], "\[IndentingNewLine]", 
 StyleBox[
  RowBox[{
   RowBox[{"Ocene", "[", 
    RowBox[{"podatki_", ",", " ", "meje_"}], "]"}], ":=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"OcenaZaMeje", "[", 
      RowBox[{"meje", ",", 
       RowBox[{
        RowBox[{"Stolpec", "[", 
         RowBox[{"podatki", ",", "\"\<To\[CHacek]ke\>\""}], "]"}], "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"Length", "[", "podatki", "]"}]}], "}"}]}], "]"}]}],
  FontWeight->"Bold"], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   StyleBox["meje",
    FontWeight->"Bold"], 
   StyleBox[" ",
    FontWeight->"Bold"], 
   StyleBox["=",
    FontWeight->"Bold"], 
   StyleBox[" ",
    FontWeight->"Bold"], 
